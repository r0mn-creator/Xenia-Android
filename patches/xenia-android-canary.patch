+# XENIA-ANDROID: Android input backend (Android only). Reports a single virtual
+# controller whose state is pushed from the Java UI via the
+# injectControllerInputNative JNI entry point. Uses NDK headers (android/input.h,
+# jni.h) — no extra link libs (the `android` lib is linked by the app target).
+add_library(xenia-hid-android STATIC)
+xe_platform_sources(xenia-hid-android ${CMAKE_CURRENT_SOURCE_DIR})
+target_link_libraries(xenia-hid-android PUBLIC xenia-base xenia-hid)
+xe_target_defaults(xenia-hid-android)
