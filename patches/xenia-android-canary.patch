diff --git a/src/xenia/kernel/xthread.cc b/src/xenia/kernel/xthread.cc
index 33610bf..3f977ba 100644
--- a/src/xenia/kernel/xthread.cc
+++ b/src/xenia/kernel/xthread.cc
@@ -7,6 +7,9 @@
