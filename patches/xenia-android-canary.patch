+// XENIA-ANDROID TEMP: deadlock diagnostic. Tracks each guest thread's CURRENT
+// wait (set on XObject::Wait entry, cleared on exit). XeDumpActiveWaits() is
+// called periodically from the still-running GPU command thread to snapshot who
+// is stuck on what (a permanently stuck wait never returns, so log-on-return
+// misses it).
+#include <atomic>
+namespace {
+struct XaWaitSlot {
+  std::atomic<uint32_t> tid{0};
+  uint32_t obj{0};
+  int objtype{0};
+  int infinite{0};
+};
+XaWaitSlot g_xa_waits[96];
+}  // namespace
+void XeRecordWaitEnter(uint32_t tid, uint32_t obj, int objtype, int infinite) {
+  if (!tid) return;
+  int free_slot = -1;
+  for (int i = 0; i < 96; i++) {
+    uint32_t t = g_xa_waits[i].tid.load(std::memory_order_relaxed);
+    if (t == tid) {
+      g_xa_waits[i].obj = obj;
+      g_xa_waits[i].objtype = objtype;
+      g_xa_waits[i].infinite = infinite;
+      return;
+    }
+    if (t == 0 && free_slot < 0) free_slot = i;
+  }
+  if (free_slot >= 0) {
+    g_xa_waits[free_slot].obj = obj;
+    g_xa_waits[free_slot].objtype = objtype;
+    g_xa_waits[free_slot].infinite = infinite;
+    g_xa_waits[free_slot].tid.store(tid, std::memory_order_relaxed);
+  }
+}
+void XeRecordWaitExit(uint32_t tid) {
+  for (int i = 0; i < 96; i++) {
+    if (g_xa_waits[i].tid.load(std::memory_order_relaxed) == tid) {
+      g_xa_waits[i].tid.store(0, std::memory_order_relaxed);
+      return;
+    }
+  }
+}
+extern "C" void XeDumpActiveWaits() {
+  for (int i = 0; i < 96; i++) {
+    uint32_t t = g_xa_waits[i].tid.load(std::memory_order_relaxed);
+    if (t) {
+      XELOGI("ACTIVE WAIT: thr={:08X} objtype={} obj={:08X} inf={}", t,
+             g_xa_waits[i].objtype, g_xa_waits[i].obj, g_xa_waits[i].infinite);
+    }
+  }
+}
