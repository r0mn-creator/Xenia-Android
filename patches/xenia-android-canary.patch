+#if XE_PLATFORM_ANDROID
+#include <pthread.h>
+#endif
 #include "xenia/kernel/xthread.h"
 
 #if !XE_PLATFORM_WIN32
@@ -511,10 +514,28 @@ X_STATUS XThread::Exit(int exit_code) {
   xe::Profiler::ThreadExit();
 
   running_ = false;
+#if XE_PLATFORM_ANDROID
+  // XENIA-ANDROID: defer releasing our self-reference until AFTER the OS thread
+  // has actually exited. threading::Thread::Exit() -> Terminate() locks THIS
+  // thread's PosixCondition mutexes; if ReleaseHandle() dropped the last
+  // reference first (detached threads, where the self-reference is the last one),
+  // the PosixThread — owned by this XThread — is freed and Terminate locks a
+  // destroyed mutex ("FORTIFY: pthread_mutex_lock called on a destroyed mutex"
+  // abort; Halo 3 hit this on every worker-thread exit). A pthread cleanup handler
+  // runs during pthread_exit (inside Thread::Exit), i.e. after Terminate's
+  // bookkeeping, so the object stays alive through it and is then released — no
+  // use-after-free and no leak. Patch #20.
+  pthread_cleanup_push(
+      [](void* self) { static_cast<XThread*>(self)->ReleaseHandle(); }, this);
+  // NOTE: this does not return!
+  xe::threading::Thread::Exit(exit_code);
+  pthread_cleanup_pop(0);  // balances the macro (unreachable)
+#else
   ReleaseHandle();
 
   // NOTE: this does not return!
   xe::threading::Thread::Exit(exit_code);
+#endif
   return X_STATUS_SUCCESS;
 }
 
