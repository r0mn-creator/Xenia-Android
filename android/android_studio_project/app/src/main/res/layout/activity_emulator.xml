<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="jp.xenia.emulator.EmulatorActivity">

    <jp.xenia.emulator.WindowSurfaceView
        android:id="@+id/emulator_surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- On-screen Xbox 360 controller overlay.
         Hidden by default; EmulatorActivity shows it when no gamepad is connected. -->
    <jp.xenia.emulator.OnScreenControlsView
        android:id="@+id/on_screen_controls"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
